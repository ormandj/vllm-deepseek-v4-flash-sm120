+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+
+from pathlib import Path
+
+import vllm.envs as envs
+from vllm.model_executor.warmup.flashinfer_sparse_mla_warmup import (
+    _flashinfer_sparse_mla_autotune_kwargs,
+)
+
+
+def test_sparse_mla_autotune_forwards_skip_ops(monkeypatch) -> None:
+    skip_ops = ["trtllm::fused_moe::gemm1", "trtllm::fused_moe::gemm2"]
+    monkeypatch.setattr(envs, "VLLM_FLASHINFER_AUTOTUNE_SKIP_OPS", skip_ops)
+
+    kwargs = _flashinfer_sparse_mla_autotune_kwargs(Path("/tmp/cache.json"))
+
+    assert kwargs == {
+        "tune_mode": True,
+        "cache": "/tmp/cache.json",
+        "skip_ops": set(skip_ops),
+    }
